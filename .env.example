# ============================================================
# SENTINEL — Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# --- Neo4j ---
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=sentinel_dev

# --- AWS ---
AWS_DEFAULT_REGION=us-east-1
# Comma-separated list of regions to scan
AWS_REGIONS=us-east-1,us-west-2
# Optional: ARN to assume for cross-account access
AWS_ASSUME_ROLE_ARN=

# --- API ---
API_PORT=8000
# Set to "true" to enable POST /graph/query (raw Cypher, dev only)
ENABLE_RAW_CYPHER=false

# --- Phase 2: Agent ---
ANTHROPIC_API_KEY=
AGENT_MODEL=claude-opus-4-6
AGENT_MAX_TOKENS=4096
# Set to "true" to enable extended thinking by default (opt-in per-request via ?thinking=true)
AGENT_ENABLE_THINKING=false
# Token budget for Claude's internal reasoning when extended thinking is active
AGENT_THINKING_BUDGET_TOKENS=8000

# --- Phase 3: CloudTrail polling (opt-in) ---
# Set ENABLE_CLOUDTRAIL_POLLING=true to start the background poller on API startup.
# AWS_ACCOUNT_ID is required when polling is enabled.
ENABLE_CLOUDTRAIL_POLLING=false
AWS_ACCOUNT_ID=
# How often (seconds) to poll CloudTrail lookup_events (default: 60)
CLOUDTRAIL_POLL_INTERVAL=60
