# ============================================================
# SENTINEL — Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# --- Neo4j ---
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
# Development default. CHANGE THIS in production — docker-compose.prod.yml will
# refuse to start if NEO4J_PASSWORD is unset.
NEO4J_PASSWORD=sentinel_dev

# --- AWS ---
AWS_DEFAULT_REGION=us-east-1
# Comma-separated list of regions to scan
AWS_REGIONS=us-east-1,us-west-2
# Optional: ARN to assume for cross-account access
AWS_ASSUME_ROLE_ARN=

# --- API ---
API_PORT=8000
# Set to "true" to enable POST /graph/query (raw Cypher, dev only)
ENABLE_RAW_CYPHER=false

# --- Phase 2: Agent ---
ANTHROPIC_API_KEY=
AGENT_MODEL=claude-opus-4-6
AGENT_MAX_TOKENS=4096
# Set to "true" to enable extended thinking by default (opt-in per-request via ?thinking=true)
AGENT_ENABLE_THINKING=false
# Token budget for Claude's internal reasoning when extended thinking is active
AGENT_THINKING_BUDGET_TOKENS=8000
# LLM provider: "anthropic" (default) or "openai" (for OpenAI-compatible endpoints)
AGENT_PROVIDER=anthropic
# For OpenAI-compatible providers (Groq, Ollama, Together AI, vLLM):
# AGENT_PROVIDER=openai
# OPENAI_API_KEY=sk-...
# AGENT_BASE_URL=http://localhost:11434/v1

# --- Phase 3: CloudTrail polling (opt-in) ---
# Set ENABLE_CLOUDTRAIL_POLLING=true to start the background poller on API startup.
# AWS_ACCOUNT_ID is required when polling is enabled.
ENABLE_CLOUDTRAIL_POLLING=false
AWS_ACCOUNT_ID=
# How often (seconds) to poll CloudTrail lookup_events (default: 60)
CLOUDTRAIL_POLL_INTERVAL=60

# --- Security ---
# Set API_KEY to a strong random secret to require X-API-Key header on all requests.
# Leave empty to disable (default, dev-friendly).
API_KEY=
# Set to "true" in production to enforce per-IP rate limits on expensive endpoints.
RATE_LIMIT_ENABLED=false

# --- Persistence ---
# Path to the SQLite database file for scan/remediation job history.
# Use an absolute path or a volume-mapped path when running in Docker.
SENTINEL_DB_PATH=./sentinel.db

# --- Docker / Ops ---
# Image registry prefix for `make docker-push` and docker-compose.prod.yml.
# Example: ghcr.io/your-org
REGISTRY=
# Image tag for builds (defaults to "latest").
IMAGE_TAG=latest
# Port exposed by Nginx in production (default: 80).
HTTP_PORT=80
